# Blockchain Storage Configuration
# Choose your preferred storage provider: ipfs, filecoin, or arweave
BLOCKCHAIN_STORAGE_PROVIDER=ipfs

# Network configuration
BLOCKCHAIN_NETWORK=mainnet

# IPFS Configuration (using Pinata as example)
BLOCKCHAIN_STORAGE_ENDPOINT=https://api.pinata.cloud/pinning/pinFileToIPFS
BLOCKCHAIN_STORAGE_API_KEY=your_pinata_api_key_here

# Alternative IPFS endpoints:
# Infura: https://ipfs.infura.io:5001/api/v0/add
# Fleek: https://api.fleek.co/storage/pins

# Filecoin Configuration
# BLOCKCHAIN_STORAGE_ENDPOINT=https://api.filecoin.io/v1/storage
# BLOCKCHAIN_STORAGE_API_KEY=your_filecoin_api_key_here

# Arweave Configuration
# BLOCKCHAIN_STORAGE_ENDPOINT=https://node1.arweave.org
# No API key required for direct node uploads

# Storage Backup Configuration
# Keep AWS as backup during migration
AWS_S3_BUCKET=your_backup_bucket
AWS_CLOUDFRONT_DOMAIN=your_backup_domain.cloudfront.net
AWS_REGION=us-east-1

# Hybrid Mode Configuration
# Enable both blockchain and traditional storage
STORAGE_HYBRID_MODE=true
STORAGE_PRIMARY=blockchain
STORAGE_BACKUP=aws
