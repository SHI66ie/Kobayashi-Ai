# AWS S3 + CloudFront Configuration
# Required for production data hosting
AWS_S3_BUCKET=kobayashiaidata
AWS_CLOUDFRONT_DOMAIN=your-cloudfront-domain.cloudfront.net
AWS_REGION=us-east-1

# Formula 1 API Configuration (Sportradar API)
# Get your API key from https://developer.sportradar.com/
# Sign up for Formula 1 API access
F1_API_KEY=your_sportradar_api_key_here

# Google Drive API Configuration (optional)
GOOGLE_DRIVE_API_KEY=your_google_drive_api_key_here

# App URL (optional)
NEXT_PUBLIC_APP_URL=http://localhost:3000
